{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/request-otp/[email]",
      "regex": "^/api/auth/request\\-otp/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPemail": "nxtPemail"
      },
      "namedRegex": "^/api/auth/request\\-otp/(?<nxtPemail>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/auth/verify-otp/[email]/[otp]",
      "regex": "^/api/auth/verify\\-otp/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPemail": "nxtPemail",
        "nxtPotp": "nxtPotp"
      },
      "namedRegex": "^/api/auth/verify\\-otp/(?<nxtPemail>[^/]+?)/(?<nxtPotp>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/kebele/[id]",
      "regex": "^/api/kebele/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/kebele/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/region/[id]",
      "regex": "^/api/region/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/region/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/religion/[id]",
      "regex": "^/api/religion/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/religion/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/woreda/[id]",
      "regex": "^/api/woreda/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/woreda/(?<nxtPid>[^/]+?)(?:/)?$"
    },
