
NEXT_PUBLIC_AUTH_APP_URL=
AUTH_API_BASE_URL=
API_BASE_URL=

# Optional: set to 1 to log auth + API proxy (multipart) URL/timing in production (server terminal only).
# In development, logs are printed without this flag.
AUTH_DEBUG=1

# Max time (ms) the Next.js server waits for multipart uploads to the main API (member create, national ID).
# Default 120000. Abort returns 504 UPLOAD_PROXY_TIMEOUT to the browser.
# API_PROXY_UPLOAD_TIMEOUT_MS=120000
